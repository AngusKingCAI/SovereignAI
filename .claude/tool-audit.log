{"timestamp": "2026-07-25T02:07:35.600027", "tool_name": "read", "tool_input": {"file_path": "C:\\SovereignAI\\Scripts\\Governance\\Hooks\\tool_audit_logger.py"}, "success": true}
{"timestamp": "2026-07-25T02:07:49.388101", "tool_name": "edit", "tool_input": {"file_path": "C:\\SovereignAI\\Scripts\\Governance\\Hooks\\tool_audit_logger.py", "old_string": "def log_tool_use(tool_name, tool_input, tool_result):\n    \"\"\"Log tool use to the unified session file.\"\"\"\n    session_file = get_current_session_file()\n    \n    if not session_file:\n        return False\n    \n    session_file_path = Path(session_file)\n    if not session_file_path.exists():\n        return False\n    \n    timestamp = datetime.now()\n    \n    try:\n        with open(session_file_path, 'a', encoding='utf-8') as f:\n            f.write(f\"\\n### Tool Use: {tool_name}\\n\")\n            f.write(f\"**Timestamp**: {timestamp.isoformat()}\\n\")\n            f.write(f\"**Tool**: {tool_name}\\n\")\n            f.write(f\"**Input**: {json.dumps(tool_input, indent=2)}\\n\")\n            f.write(f\"**Result**: {json.dumps(tool_result, indent=2)}\\n\")\n            f.write(\"---\\n\")\n        return True\n    except Exception:\n        return False", "new_string": "def format_large_content(content, max_chars=500):\n    \"\"\"Format large content for better readability.\"\"\"\n    content_str = json.dumps(content, indent=2) if not isinstance(content, str) else content\n    \n    if len(content_str) <= max_chars:\n        return content_str\n    \n    # Truncate and add summary\n    truncated = content_str[:max_chars]\n    remaining = len(content_str) - max_chars\n    return f\"{truncated}\\n\\n... [Content truncated: {remaining} additional characters]\"\n\ndef summarize_tool_input(tool_name, tool_input):\n    \"\"\"Create a readable summary of tool input.\"\"\"\n    if tool_name == 'write':\n        file_path = tool_input.get('file_path', 'unknown')\n        content_length = len(tool_input.get('content', ''))\n        return f\"File: {file_path} ({content_length} characters)\"\n    elif tool_name == 'edit':\n        file_path = tool_input.get('file_path', 'unknown')\n        old_length = len(tool_input.get('old_string', ''))\n        new_length = len(tool_input.get('new_string', ''))\n        return f\"File: {file_path} (edit: {old_length} -> {new_length} chars)\"\n    elif tool_name == 'read':\n        file_path = tool_input.get('file_path', 'unknown')\n        return f\"File: {file_path}\"\n    elif tool_name == 'exec':\n        command = tool_input.get('command', '')\n        return f\"Command: {command[:100]}{'...' if len(command) > 100 else ''}\"\n    else:\n        return f\"Input: {json.dumps(tool_input, indent=2)[:200]}\"\n\ndef log_tool_use(tool_name, tool_input, tool_result):\n    \"\"\"Log tool use to the unified session file with improved formatting.\"\"\"\n    session_file = get_current_session_file()\n    \n    if not session_file:\n        return False\n    \n    session_file_path = Path(session_file)\n    if not session_file_path.exists():\n        return False\n    \n    timestamp = datetime.now()\n    \n    try:\n        with open(session_file_path, 'a', encoding='utf-8') as f:\n            f.write(f\"\\n### Tool Use: {tool_name}\\n\")\n            f.write(f\"**Timestamp**: {timestamp.isoformat()}\\n\")\n            f.write(f\"**Tool**: {tool_name}\\n\")\n            \n            # Use summary for certain tools, full content for others\n            if tool_name in ['write', 'edit', 'read', 'exec']:\n                summary = summarize_tool_input(tool_name, tool_input)\n                f.write(f\"**Input Summary**: {summary}\\n\")\n                \n                # Only show full content for smaller operations\n                if tool_name in ['write', 'edit']:\n                    content_length = len(tool_input.get('content', '') if tool_name == 'write' else tool_input.get('new_string', ''))\n                    if content_length < 300:  # Only show small content\n                        f.write(f\"**Input**: {format_large_content(tool_input, max_chars=300)}\\n\")\n                    else:\n                        f.write(f\"**Input**: [Large content - {content_length} characters]\\n\")\n                else:\n                    f.write(f\"**Input**: {format_large_content(tool_input, max_chars=300)}\\n\")\n            else:\n                f.write(f\"**Input**: {format_large_content(tool_input, max_chars=300)}\\n\")\n            \n            f.write(f\"**Result**: {format_large_content(tool_result, max_chars=300)}\\n\")\n            f.write(\"---\\n\")\n        return True\n    except Exception:\n        return False"}, "success": true}
{"timestamp": "2026-07-25T02:07:55.078355", "tool_name": "edit", "tool_input": {"file_path": "C:\\SovereignAI\\Scripts\\Governance\\Hooks\\tool_audit_logger.py", "old_string": "def main():\n    \"\"\"Log all tool calls to audit trail.\"\"\"\n    try:\n        # Read event data from stdin\n        data = sys.stdin.read()\n        if data.strip():\n            env_vars = json.loads(data)\n        else:\n            env_vars = {}\n        \n        # Extract tool information\n        tool_name = env_vars.get('tool_name', 'unknown')\n        tool_input = env_vars.get('tool_input', {})\n        tool_result = env_vars.get('tool_result', {})\n        \n        # Log to unified session file\n        log_tool_use(tool_name, tool_input, tool_result)\n        \n        # Also create audit log entry for compliance\n        timestamp = datetime.now().isoformat()\n        log_entry = {\n            \"timestamp\": timestamp,\n            \"tool_name\": tool_name,\n            \"tool_input\": tool_input,\n            \"success\": tool_result.get('success', True)\n        }\n        \n        # Write to audit log\n        log_file = Path(\"C:/SovereignAI/.claude/tool-audit.log\")\n        log_file.parent.mkdir(exist_ok=True)\n        \n        with open(log_file, 'a', encoding='utf-8') as f:\n            f.write(json.dumps(log_entry) + \"\\n\")\n        \n        return 0\n        \n    except Exception as e:\n        # Don't block operations even if logging fails\n        return 0\n\nif __name__ == \"__main__\":\n    sys.exit(main())", "new_string": "def main():\n    \"\"\"Log all tool calls to audit trail.\"\"\"\n    try:\n        # Read event data from stdin\n        data = sys.stdin.read()\n        if data.strip():\n            env_vars = json.loads(data)\n        else:\n            env_vars = {}\n        \n        # Extract tool information\n        tool_name = env_vars.get('tool_name', 'unknown')\n        tool_input = env_vars.get('tool_input', {})\n        tool_result = env_vars.get('tool_result', {})\n        \n        # Log to unified session file with improved formatting\n        log_tool_use(tool_name, tool_input, tool_result)\n        \n        # Also create audit log entry for compliance\n        timestamp = datetime.now().isoformat()\n        log_entry = {\n            \"timestamp\": timestamp,\n            \"tool_name\": tool_name,\n            \"tool_input\": tool_input,\n            \"success\": tool_result.get('success', True)\n        }\n        \n        # Write to audit log\n        log_file = Path(\"C:/SovereignAI/.claude/tool-audit.log\")\n        log_file.parent.mkdir(exist_ok=True)\n        \n        with open(log_file, 'a', encoding='utf-8') as f:\n            f.write(json.dumps(log_entry) + \"\\n\")\n        \n        return 0\n        \n    except Exception as e:\n        # Don't block operations even if logging fails\n        return 0\n\nif __name__ == \"__main__\":\n    sys.exit(main())"}, "success": true}
