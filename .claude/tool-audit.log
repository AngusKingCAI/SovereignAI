{"timestamp": "2026-07-25T02:16:10.848636", "tool_name": "edit", "tool_input": {"file_path": "C:\\SovereignAI\\Scripts\\Governance\\Hooks\\tool_audit_logger.py", "old_string": "def format_large_content(content, max_chars=500):\n    \"\"\"Format large content for better readability.\"\"\"\n    content_str = json.dumps(content, indent=2) if not isinstance(content, str) else content\n    \n    if len(content_str) <= max_chars:\n        return content_str\n    \n    # Truncate and add summary\n    truncated = content_str[:max_chars]\n    remaining = len(content_str) - max_chars\n    return f\"{truncated}\\n\\n... [Content truncated: {remaining} additional characters]\"\n\ndef summarize_tool_input(tool_name, tool_input):\n    \"\"\"Create a readable summary of tool input.\"\"\"\n    if tool_name == 'write':\n        file_path = tool_input.get('file_path', 'unknown')\n        content_length = len(tool_input.get('content', ''))\n        return f\"File: {file_path} ({content_length} characters)\"\n    elif tool_name == 'edit':\n        file_path = tool_input.get('file_path', 'unknown')\n        old_length = len(tool_input.get('old_string', ''))\n        new_length = len(tool_input.get('new_string', ''))\n        return f\"File: {file_path} (edit: {old_length} -> {new_length} chars)\"\n    elif tool_name == 'read':\n        file_path = tool_input.get('file_path', 'unknown')\n        return f\"File: {file_path}\"\n    elif tool_name == 'exec':\n        command = tool_input.get('command', '')\n        return f\"Command: {command[:100]}{'...' if len(command) > 100 else ''}\"\n    else:\n        return f\"Input: {json.dumps(tool_input, indent=2)[:200]}\"\n\ndef log_tool_use(tool_name, tool_input, tool_result):\n    \"\"\"Log tool use to the unified session file with improved formatting.\"\"\"\n    session_file = get_current_session_file()\n    \n    if not session_file:\n        return False\n    \n    session_file_path = Path(session_file)\n    if not session_file_path.exists():\n        return False\n    \n    timestamp = datetime.now()\n    \n    try:\n        with open(session_file_path, 'a', encoding='utf-8') as f:\n            f.write(f\"\\n### Tool Use: {tool_name}\\n\")\n            f.write(f\"**Timestamp**: {timestamp.isoformat()}\\n\")\n            f.write(f\"**Tool**: {tool_name}\\n\")\n            \n            # Use summary for certain tools, full content for others\n            if tool_name in ['write', 'edit', 'read', 'exec']:\n                summary = summarize_tool_input(tool_name, tool_input)\n                f.write(f\"**Input Summary**: {summary}\\n\")\n                \n                # Only show full content for smaller operations\n                if tool_name in ['write', 'edit']:\n                    content_length = len(tool_input.get('content', '') if tool_name == 'write' else tool_input.get('new_string', ''))\n                    if content_length < 300:  # Only show small content\n                        f.write(f\"**Input**: {format_large_content(tool_input, max_chars=300)}\\n\")\n                    else:\n                        f.write(f\"**Input**: [Large content - {content_length} characters]\\n\")\n                else:\n                    f.write(f\"**Input**: {format_large_content(tool_input, max_chars=300)}\\n\")\n            else:\n                f.write(f\"**Input**: {format_large_content(tool_input, max_chars=300)}\\n\")\n            \n            f.write(f\"**Result**: {format_large_content(tool_result, max_chars=300)}\\n\")\n            f.write(\"---\\n\")\n        return True\n    except Exception:\n        return False", "new_string": "def format_large_content(content, max_chars=2000):\n    \"\"\"Format large content for better readability.\"\"\"\n    content_str = json.dumps(content, indent=2) if not isinstance(content, str) else content\n    \n    if len(content_str) <= max_chars:\n        return content_str\n    \n    # Truncate and add summary\n    truncated = content_str[:max_chars]\n    remaining = len(content_str) - max_chars\n    return f\"{truncated}\\n\\n... [Content truncated: {remaining} additional characters]\"\n\ndef summarize_tool_input(tool_name, tool_input):\n    \"\"\"Create a readable summary of tool input.\"\"\"\n    if tool_name == 'write':\n        file_path = tool_input.get('file_path', 'unknown')\n        content_length = len(tool_input.get('content', ''))\n        return f\"File: {file_path} ({content_length} characters)\"\n    elif tool_name == 'edit':\n        file_path = tool_input.get('file_path', 'unknown')\n        old_length = len(tool_input.get('old_string', ''))\n        new_length = len(tool_input.get('new_string', ''))\n        return f\"File: {file_path} (edit: {old_length} -> {new_length} chars)\"\n    elif tool_name == 'read':\n        file_path = tool_input.get('file_path', 'unknown')\n        return f\"File: {file_path}\"\n    elif tool_name == 'exec':\n        command = tool_input.get('command', '')\n        return f\"Command: {command[:200]}{'...' if len(command) > 200 else ''}\"\n    else:\n        return f\"Input: {json.dumps(tool_input, indent=2)[:500]}\"\n\ndef log_tool_use(tool_name, tool_input, tool_result):\n    \"\"\"Log tool use to the unified session file with improved formatting.\"\"\"\n    session_file = get_current_session_file()\n    \n    if not session_file:\n        return False\n    \n    session_file_path = Path(session_file)\n    if not session_file_path.exists():\n        return False\n    \n    timestamp = datetime.now()\n    \n    try:\n        with open(session_file_path, 'a', encoding='utf-8') as f:\n            f.write(f\"\\n### Tool Use: {tool_name}\\n\")\n            f.write(f\"**Timestamp**: {timestamp.isoformat()}\\n\")\n            f.write(f\"**Tool**: {tool_name}\\n\")\n            \n            # Use summary for certain tools, full content for others\n            if tool_name in ['write', 'edit', 'read', 'exec']:\n                summary = summarize_tool_input(tool_name, tool_input)\n                f.write(f\"**Input Summary**: {summary}\\n\")\n                \n                # Show full content for most operations, only truncate very large ones\n                if tool_name in ['write', 'edit']:\n                    content_length = len(tool_input.get('content', '') if tool_name == 'write' else tool_input.get('new_string', ''))\n                    if content_length < 5000:  # Show content up to 5000 chars\n                        # For edits, show both old and new content if reasonable size\n                        if tool_name == 'edit':\n                            old_string = tool_input.get('old_string', '')\n                            new_string = tool_input.get('new_string', '')\n                            f.write(f\"**Old String** ({len(old_string)} chars):\\n```\\n{old_string}\\n```\\n\")\n                            f.write(f\"**New String** ({len(new_string)} chars):\\n```\\n{new_string}\\n```\\n\")\n                        else:\n                            content = tool_input.get('content', '')\n                            f.write(f\"**Content** ({len(content)} chars):\\n```\\n{content}\\n```\\n\")\n                    else:\n                        # Show first 2000 chars for very large content\n                        if tool_name == 'edit':\n                            new_string = tool_input.get('new_string', '')\n                            preview = new_string[:2000]\n                            f.write(f\"**Content Preview** (first 2000 of {len(new_string)} chars):\\n```\\n{preview}\\n```\\n\")\n                            f.write(f\"... [{len(new_string) - 2000} additional characters]\\n\")\n                        else:\n                            content = tool_input.get('content', '')\n                            preview = content[:2000]\n                            f.write(f\"**Content Preview** (first 2000 of {len(content)} chars):\\n```\\n{preview}\\n```\\n\")\n                            f.write(f\"... [{len(content) - 2000} additional characters]\\n\")\n                else:\n                    # For read and exec, show the full input\n                    f.write(f\"**Input**: {format_large_content(tool_input, max_chars=2000)}\\n\")\n            else:\n                f.write(f\"**Input**: {format_large_content(tool_input, max_chars=2000)}\\n\")\n            \n            f.write(f\"**Result**: {format_large_content(tool_result, max_chars=2000)}\\n\")\n            f.write(\"---\\n\")\n        return True\n    except Exception:\n        return False"}, "success": true}
