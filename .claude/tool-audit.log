{"timestamp": "2026-07-25T03:06:37.418020", "tool_name": "exec", "tool_input": {"command": "cd C:/SovereignAI && python -c \"\nimport json\nfrom pathlib import Path\n\n# Read current hooks configuration\nhooks_file = Path('.devin/hooks.v1.json')\nwith open(hooks_file, 'r', encoding='utf-8') as f:\n    hooks_config = json.load(f)\n\n# Re-enable block_destructive hook\nfor matcher in hooks_config['PreToolUse']:\n    if matcher.get('matcher') == 'exec':\n        matcher['hooks'] = [{\n            'type': 'command',\n            'command': 'python C:/SovereignAI/Scripts/Governance/Hooks/block_destructive.py',\n            'timeout': 10\n        }]\n        break\n\n# Write back\nwith open(hooks_file, 'w', encoding='utf-8') as f:\n    json.dump(hooks_config, f, indent=2)\n\nprint('Re-enabled block_destructive hook')\n\""}, "success": true}
